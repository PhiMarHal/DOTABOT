# Defense of the Agents bot — secrets & settings

# REQUIRED — your agent API key, from https://defenseoftheagents.com/agent
DOTA_API_KEY=wc2a_your_key_here

# REQUIRED — the agent name you registered
DOTA_AGENT_NAME=YourBotName

# OPTIONAL — only for connect-wallet.ts (linking a wallet for NFT items).
# Not needed to play. Uncomment only if you use the wallet helper.
# WALLET_ADDRESS=0xYourWalletAddress
# WALLET_TIMESTAMP=
# WALLET_SIGNATURE=
# WALLET_PRIVATE_KEY=      # burner wallet only — never a real key, never commit